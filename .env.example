# =============================================
# CL-BEDS Backend Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================

# App
APP_NAME=CL-BEDS
DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret-key-min-32-chars

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL (Supabase connection string with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres.your-project:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider — choose one: openai | anthropic | groq
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.7

# CORS (JSON array of allowed origins)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ML Models
BURNOUT_MODEL_PATH=app/models/weights/burnout_model.pt
ROBERTA_MODEL_NAME=cardiffnlp/twitter-roberta-base-emotion
